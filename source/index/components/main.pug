#main
    #main-block-top
        #main-block-content 
            h1#content-title !{content.contentTitleText}
            p#content-slogan !{sharedContent.contentSloganText}
            #doctor-login-block
                .login-button.click-button
                    .login-text !{content.doctorsLoginButtonText}
                    .login-arrow: svg: use(href="#svg-right-chevron")
            #patient-login-block
                .login-button.click-button
                    .login-text !{content.patientsLoginButtonText}
                    .login-arrow: svg: use(href="#svg-right-chevron")
            #susdoxshare-login-block
                .login-button.click-button
                    .login-text !{content.susdoxShareLoginButtonText}
                    .login-arrow: svg: use(href="#svg-down-chevron")
                include ../../susdoxshareloginmodule/susdoxsharelogin.pug
            //- #support-block: include ../../supportbuttonmodule/supportbutton.pug
        #main-block-decoration 
            p !{content.serviceNotice}

